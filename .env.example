# Copy this file to .env before running Docker Compose.

# Runtime
NODE_ENV=production
APP_PORT=4973
BACKEND_PORT=4973
FRONTEND_PORT=3000
ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4973

# PostgreSQL
DB_HOST=database
DB_PORT=5432
DB_USER=errortracer
DB_PASSWORD=change-me
DB_NAME=errortracer
DATABASE_PUBLISHED_PORT=5432

# Auth and application secrets
JWT_SECRET=change-me
ACCESS_TOKEN_SECRET=change-me
REFRESH_TOKEN_SECRET=change-me
APP_KEY_GENERATOR=change-me-32-character-minimum-key

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_TO_FILE=false
LOG_DIR=logs
LOG_ERROR_FILE=error.log
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

